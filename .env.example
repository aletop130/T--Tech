# Detour system environment configuration (example)
DETOUR_ENABLED=true
DETOUR_SCREENING_THRESHOLD_KM=5.0
DETOUR_SCREENING_WINDOW_HOURS=72
DETOUR_MAX_ITERATIONS_PLANNER=3
DETOUR_AUTO_APPROVE_LOW_RISK=false
DETOUR_REGOLO_MODEL=qwen3.5-122b
REGOLO_FALLBACK_MODEL=gpt-oss-120b
DETOUR_REGOLO_TEMPERATURE=0.2

# Frontend mode: "dev" for development (npm run dev) or "build" for production (npm run build && npm start)
FRONTEND_MODE=build
