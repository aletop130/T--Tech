# =============================================================================
# HORUS — Environment Configuration (example)
# Copy this file to `.env` and fill in real values where needed.
# Services boot with the defaults below; AI / external feeds require keys.
# =============================================================================

# --- Application ---
SECRET_KEY=change-me-in-production
DEBUG=false
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_USER=sda_user
POSTGRES_PASSWORD=sda_secret
POSTGRES_DB=sda_db

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret

# --- Frontend ---
# "dev" = npm run dev (HMR) | "build" = npm run build && npm start
FRONTEND_MODE=build

# =============================================================================
# AI Gateway — Regolo
# =============================================================================
REGOLO_API_KEY=
DETOUR_REGOLO_MODEL=qwen3.5-122b
REGOLO_FALLBACK_MODEL=gpt-oss-120b
DETOUR_REGOLO_TEMPERATURE=0.2

# =============================================================================
# Detour (collision-avoidance) tuning
# =============================================================================
DETOUR_ENABLED=true
DETOUR_SCREENING_THRESHOLD_KM=5.0
DETOUR_SCREENING_WINDOW_HOURS=72
DETOUR_MAX_ITERATIONS_PLANNER=3
DETOUR_AUTO_APPROVE_LOW_RISK=false

# =============================================================================
# External data providers (optional — leave blank to disable that feed)
# =============================================================================

# N2YO — satellite passes
N2YO_API_KEY=

# Space-Track (USSPACECOM)
SPACETRACK_USER=
SPACETRACK_PASS=

# Copernicus Data Space (Sentinel imagery)
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# ESA DISCOS (space object database)
ESA_DISCOS_TOKEN=

# OpenSky Network (aircraft ADS-B tracking)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# MyShipTracking (vessel tracking)
MYSHIPTRACKING_API_KEY=
